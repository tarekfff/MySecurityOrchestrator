# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# PDF source (relative or absolute path)
PDF_PATH=The Web Application Hacker's Handbook - Finding and Exploiting Security Flaws, 2nd Edition by Dafydd Stuttard, Marcus Pinto.pdf
# Optional: External webhook to share generated workflows with teammates
FRIEND_WEBHOOK_URL=https://hooks.slack.com/services/...
# Ingestion settings
EMBED_BATCH_SIZE=20
EMBED_DELAY_SECONDS=1.0
CHUNK_MAX_WORDS=250
CHUNK_MIN_WORDS=50

# API
API_HOST=0.0.0.0
API_PORT=8000

